   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "LogisticRegression: среднее F1 = 0.75\n",
      "LinearSVC: среднее F1 = 0.77\n",
      "SGDClassifier: среднее F1 = 0.71\n",
      "Лучшая модель по результатам CV: LinearSVC\n"
     ]
    }
   ],
   "source": [
    "pipelines = {\n",
    "    'LogisticRegression': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(\n",
    "            ngram_range=(1, 2),\n",
    "            max_df=0.9,\n",
    "            min_df=3\n",
    "        )),\n",
    "        ('model', LogisticRegression(\n",
    "            max_iter=1000,\n",
    "            class_weight='balanced',\n",
    "            random_state=RANDOM_STATE\n",
    "        ))\n",
    "    ]),\n",
    "    \n",
    "    'LinearSVC': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(\n",
    "            ngram_range=(1, 2),\n",
    "            max_df=0.9,\n",
    "            min_df=3\n",
    "        )),\n",
    "        ('model', LinearSVC(\n",
    "            class_weight='balanced'\n",
    "        ))\n",
    "    ]),\n",
    "    \n",
    "    'SGDClassifier': Pipeline([\n",
    "        ('tfidf', TfidfVectorizer(\n",
    "            ngram_range=(1, 2),\n",
    "            max_df=0.9,\n",
    "            min_df=3\n",
    "        )),\n",
    "        ('model', SGDClassifier(\n",
    "            loss='log',\n",
    "            class_weight='balanced',\n",
    "            random_state=RANDOM_STATE\n",
    "        ))\n",
    "    ])\n",
    "}\n",
    "cv_results = {}\n",
    "\n",
    "for name, pipeline in pipelines.items():\n",
    "    scores = cross_val_score(\n",
    "        pipeline,\n",
    "        X_train,\n",
    "        y_train,\n",
    "        cv=3,\n",
    "        scoring='f1',\n",
    "        n_jobs=-1\n",
    "    )\n",
    "    cv_results[name] = scores.mean()\n",
    "    print(f'{name}: среднее F1 = {round(scores.mean(), 2)}')\n",
    "\n",
    "    best_model_name = max(cv_results, key=cv_results.get)\n",
    "best_pipeline = pipelines[best_model_name]\n",
    "\n",
    "print('Лучшая модель по результатам CV:', best_model_name)"
   ]
  },
